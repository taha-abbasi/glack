// Copy this file to Secrets.xcconfig and fill in your own values.
// Secrets.xcconfig is gitignored. Never commit it.
//
// Glack Desktop OAuth client ID + secret. Create one at:
//   https://console.cloud.google.com/apis/credentials
// Type: "Desktop app". Google requires both client_id AND client_secret
// even with PKCE — they document the secret as "public" for Desktop apps.
GOOGLE_OAUTH_CLIENT_ID = YOUR_CLIENT_ID_HERE.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET = YOUR_CLIENT_SECRET_HERE
